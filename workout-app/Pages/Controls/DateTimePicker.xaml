<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/maui/global"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="workout_app.Pages.Controls.DateTimePicker"
             x:Name="root">

    <VerticalStackLayout Spacing="24">
        <!-- Date Selection Tile -->
        <Grid>
            <Border
         HeightRequest="70"
         BackgroundColor="White"
         Stroke="White"
         StrokeThickness="2">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="25"/>
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="Black"
                     Opacity="0.25"
                     Radius="8"
                     Offset="4,4" />
                </Border.Shadow>

                <Grid ColumnDefinitions="*, *, *">

                    <Image 
                 Grid.Column="0"
                 Source="calendar" 
                 HeightRequest="50" 
                 WidthRequest="50"
                 Aspect="AspectFit"
                 VerticalOptions="Center"
                 HorizontalOptions="Start"
                 Margin="20,0,0,0" />

                    <Label 
                 Grid.Column="1"
                 Text="{Binding SelectedDateDisplay, Source={x:Reference root}}"
                 FontSize="Large"
                 FontAttributes="Bold"
                 TextColor="Black"
                 VerticalOptions="Center"
                 HorizontalOptions="Start"/>

                </Grid>
            </Border>

            <!-- Invisible DatePicker covering entire tile -->
            <DatePicker 
         x:Name="bpDatePicker"
         Date="{Binding SelectedDate, Source={x:Reference root}}"
         BackgroundColor="Transparent"
         Opacity="0.01"
         HorizontalOptions="Fill"
         VerticalOptions="Fill" />
        </Grid>


        <!-- Time Selection Tile -->
        <Grid IsVisible="{Binding ShowTimePicker, Source={x:Reference root}}">
            <Border
         HeightRequest="70"
         BackgroundColor="White"
         Stroke="White"
         StrokeThickness="2">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="25"/>
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="Black"
                     Opacity="0.25"
                     Radius="8"
                     Offset="4,4" />
                </Border.Shadow>

                <Grid ColumnDefinitions="*, *, *">
                    <Image 
                 Grid.Column="0"
                 Source="clock" 
                 HeightRequest="50" 
                 WidthRequest="50"
                 Aspect="AspectFit" 
                 VerticalOptions="Center"
                 HorizontalOptions="Start"
                 Margin="20,0,0,0" />

                    <Label 
                 Grid.Column="1"
                 Text="{Binding SelectedTimeDisplay, Source={x:Reference root}}"
                 FontSize="Large"
                 FontAttributes="Bold"
                 TextColor="Black"
                 VerticalOptions="Center"
                 HorizontalOptions="Start"/>
                </Grid >
            </Border>

            <!-- Invisible TimePicker covering entire tile -->
            <TimePicker 
         x:Name="bpTimePicker"
         Time="{Binding SelectedTime, Source={x:Reference root}}"
         BackgroundColor="Transparent"
         Opacity="0.01"
         HorizontalOptions="Fill"
         VerticalOptions="Fill" />
        </Grid>

    </VerticalStackLayout>
    
</ContentView>
