<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/maui/global"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="workout_app.Pages.Controls.DataSummary"
             x:Name="DataSummaryControl">


    <Grid ColumnDefinitions="*, *">

        <Border
            Grid.Column="0"
            BackgroundColor="White"
            Stroke="#e0e0e0"
            StrokeThickness="1"
            Padding="10">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="65"/>
            </Border.StrokeShape>

            <Border.Shadow>
                <Shadow 
                Brush="Black"
                Opacity="0.15"
                Radius="5"
                Offset="2,2" />
            </Border.Shadow>

            <VerticalStackLayout>
                <Label 
                    Grid.Row="0"
                    Text="Mittelwert"
                    TextColor="Gray"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    FontSize="Medium"
                    Margin="0,20,0,10"/>
                <Label 
                    Text="{Binding Source={x:Reference DataSummaryControl}, Path=AverageReading}"
                    FontSize="Large"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
                <Label 
                    Grid.Row="0"
                    Text="{Binding Source={x:Reference DataSummaryControl}, Path=Unit}"
                    FontAttributes="Bold"
                    FontSize="Medium"
                    HorizontalOptions="Center"
                    TextColor="Gray"/>
            </VerticalStackLayout>

        </Border>

        <Border
            Grid.Column="1"
            BackgroundColor="White"
            Stroke="#e0e0e0"
            StrokeThickness="1"
            Padding="10">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="65"/>
            </Border.StrokeShape>

            <Border.Shadow>
                <Shadow 
                Brush="Black"
                Opacity="0.15"
                Radius="5"
                Offset="2,2" />
            </Border.Shadow>

            <VerticalStackLayout>
                <Label 
                    Grid.Row="0"
                    Text="Letzte Eingabe"
                    TextColor="Gray"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    FontSize="Medium"
                    Margin="0,20,0,10"/>
                <Label 
                    Text="{Binding Source={x:Reference DataSummaryControl}, Path=LastReading}"
                    FontSize="Large"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
                <Label
                    Grid.Row="0"
                    Text="{Binding Source={x:Reference DataSummaryControl}, Path=Unit}"
                    FontAttributes="Bold"
                    FontSize="Medium"
                    HorizontalOptions="Center"
                    TextColor="Gray"/>
            </VerticalStackLayout>

        </Border>

    </Grid>
    
</ContentView>
