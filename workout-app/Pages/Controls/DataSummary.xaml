<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/maui/global"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="workout_app.Pages.Controls.DataSummary"
             x:Name="DataSummaryControl">


    <Grid ColumnDefinitions="*, *"
          ColumnSpacing="20">

        <Border Grid.Column="0">

            <VerticalStackLayout 
                VerticalOptions="Center"
                Margin="10">
                
                <Label 
                    Text="Mittelwert"
                    TextColor="Gray"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    FontSize="Medium"/>
                <Label 
                    Text="{Binding Source={x:Reference DataSummaryControl}, Path=AverageReading}"
                    FontSize="Large"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
                <Label 
                    Text="{Binding Source={x:Reference DataSummaryControl}, Path=Unit}"
                    FontAttributes="Bold"
                    FontSize="Medium"
                    HorizontalOptions="Center"
                    TextColor="Gray"/>
            </VerticalStackLayout>

        </Border>

        <Border Grid.Column="1">

            <VerticalStackLayout 
                VerticalOptions="Center"
                Margin="10">
                
                <Label 
                    Text="Letzte Eingabe"
                    TextColor="Gray"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    FontSize="Medium"/>
                <Label 
                    Text="{Binding Source={x:Reference DataSummaryControl}, Path=LastReading}"
                    FontSize="Large"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
                <Label
                    Text="{Binding Source={x:Reference DataSummaryControl}, Path=Unit}"
                    FontAttributes="Bold"
                    FontSize="Medium"
                    HorizontalOptions="Center"
                    TextColor="Gray"/>
            </VerticalStackLayout>

        </Border>

    </Grid>
    
</ContentView>
