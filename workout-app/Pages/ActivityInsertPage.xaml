<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/maui/global"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="workout_app.Pages.ActivityInsertPage"
             x:DataType="ActivityInsertPageModel"
             HideSoftInputOnTapped="True"
             Title="Aktivität eintragen">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20">

            <!-- DateTime Picker Control -->
            <DateTimePicker
                SelectedDate="{Binding DateTimePicker.SelectedDate}"
                SelectedTime="{Binding DateTimePicker.SelectedTime}"
                SelectedDateDisplay="{Binding DateTimePicker.SelectedDateDisplay}"
                SelectedTimeDisplay="{Binding DateTimePicker.SelectedTimeDisplay}"/>

            <!-- Activity Type -->
            <Border Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Aktivität" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Gray500}"/>
                    
                    <Border BackgroundColor="{StaticResource wa-color-input}"
                            WidthRequest="240"
                            HeightRequest="44"
                            Shadow="{x:Null}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Picker
                            Title="Aktivität wählen..."
                            TitleColor="LightGray"
                            ItemsSource="{Binding AvailableActivities}"
                            SelectedItem="{Binding SelectedActivityType}"
                            FontSize="16"
                            TextColor="Black"
                            BackgroundColor="Transparent"
                            HorizontalTextAlignment="Center"/>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Duration -->
            <Border Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Dauer" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Gray500}"/>

                    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto"
                          ColumnSpacing="8"
                          HorizontalOptions="Center">

                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource wa-color-input}"
                                Stroke="{StaticResource wa-color-input}"
                                Shadow="{x:Null}"
                                WidthRequest="92"
                                HeightRequest="44">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Entry
                                Text="{Binding SelectedHours, Mode=TwoWay}"
                                Placeholder="0"
                                PlaceholderColor="LightGray"
                                Keyboard="Numeric"
                                MaxLength="2"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="{StaticResource Gray500}"
                                BackgroundColor="Transparent"
                                HorizontalTextAlignment="Center"
                                VerticalTextAlignment="Center"/>
                        </Border>
                        <Label Grid.Column="1"
                               Text="h"
                               FontAttributes="Bold"
                               FontSize="15"
                               VerticalTextAlignment="Center"
                               TextColor="{StaticResource Gray500}"/>

                        <Border Grid.Column="2"
                                BackgroundColor="{StaticResource wa-color-input}"
                                Stroke="{StaticResource wa-color-input}"
                                Shadow="{x:Null}"
                                WidthRequest="92"
                                HeightRequest="44">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Entry
                                Text="{Binding SelectedMinutes, Mode=TwoWay}"
                                Placeholder="0"
                                PlaceholderColor="LightGray"
                                Keyboard="Numeric"
                                MaxLength="2"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="{StaticResource Gray500}"
                                BackgroundColor="Transparent"
                                HorizontalTextAlignment="Center"
                                VerticalTextAlignment="Center"/>
                        </Border>
                        <Label Grid.Column="3"
                               Text="min"
                               FontAttributes="Bold"
                               FontSize="15"
                               VerticalTextAlignment="Center"
                               TextColor="{StaticResource Gray500}"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Distance & Altitude -->
            <Border Padding="16" IsVisible="{Binding DistanceEnabled}">
                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="16" HorizontalOptions="Start">

                    <VerticalStackLayout Grid.Column="0" Spacing="6">
                        <Label Text="Distanz" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Gray500}"/>
                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6" HorizontalOptions="Start">
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource wa-color-input}"
                                    HeightRequest="44"
                                    WidthRequest="110"
                                    Shadow="{x:Null}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry
                                    Text="{Binding Distance, Mode=TwoWay}"
                                    Placeholder="0"
                                    PlaceholderColor="LightGray"
                                    Keyboard="Numeric"
                                    FontSize="15"
                                    TextColor="{StaticResource Gray500}"
                                    BackgroundColor="Transparent"
                                    HorizontalTextAlignment="End"
                                    Margin="0,0,10,0"
                                    MaxLength="6"/>
                            </Border>
                            <Label Grid.Column="1"
                                   Text="km"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray500}"
                                   VerticalTextAlignment="Center"/>
                        </Grid>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                        <Label Text="Höhenmeter" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Gray500}"/>
                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6" HorizontalOptions="Start">
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource wa-color-input}"
                                    HeightRequest="44"
                                    WidthRequest="110"
                                    Shadow="{x:Null}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry
                                    Text="{Binding Altitude, Mode=TwoWay}"
                                    Placeholder="0"
                                    PlaceholderColor="LightGray"
                                    Keyboard="Numeric"
                                    FontSize="15"
                                    TextColor="{StaticResource Gray500}"
                                    BackgroundColor="Transparent"
                                    HorizontalTextAlignment="End"
                                    Margin="0,0,10,0"
                                    MaxLength="5"/>
                            </Border>
                            <Label Grid.Column="1"
                                   Text="hm"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray500}"
                                   VerticalTextAlignment="Center"/>
                        </Grid>
                    </VerticalStackLayout>

                </Grid>
            </Border>

            <!-- Save Button -->
            <BasicButton
                Text="Speichern"
                Margin="10,8,10,0"
                Command="{Binding SaveActivityCommand}"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
