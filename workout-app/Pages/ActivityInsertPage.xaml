<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/maui/global"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="workout_app.Pages.ActivityInsertPage"
             x:DataType="ActivityInsertPageModel"
             HideSoftInputOnTapped="True"
             Title="{x:Static AppResources.activity_insert_title}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20">

            <!-- DateTime Picker Control -->
            <DateTimePicker
                SelectedDate="{Binding DateTimePicker.SelectedDate}"
                SelectedTime="{Binding DateTimePicker.SelectedTime}"
                SelectedDateDisplay="{Binding DateTimePicker.SelectedDateDisplay}"
                SelectedTimeDisplay="{Binding DateTimePicker.SelectedTimeDisplay}"/>

            <!-- Activity Type -->
            <Border Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{x:Static AppResources.activity}" Style="{StaticResource WaSectionLabelStyle}"/>
                    
                    <Border Style="{StaticResource WaCompactInputBorderStyle}"
                            WidthRequest="240">
                        <Picker
                            Title="{x:Static AppResources.activity_select_title}"
                            TitleColor="LightGray"
                            ItemsSource="{Binding AvailableActivities}"
                            SelectedItem="{Binding SelectedActivityType}"
                            FontSize="16"
                            TextColor="Black"
                            BackgroundColor="Transparent"
                            HorizontalTextAlignment="Center"/>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Duration -->
            <Border Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{x:Static AppResources.duration}" Style="{StaticResource WaSectionLabelStyle}"/>

                    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto"
                          ColumnSpacing="8"
                          HorizontalOptions="Center">

                        <Border Grid.Column="0"
                                Style="{StaticResource WaCompactInputBorderStyle}"
                                WidthRequest="92">
                            <Entry
                                Style="{StaticResource WaCompactNumericEntryStyle}"
                                Text="{Binding SelectedHours, Mode=TwoWay}"
                                FontAttributes="Bold"
                                MaxLength="2"/>
                        </Border>
                        <Label Grid.Column="1"
                               Text="{x:Static AppResources.unit_h}"
                               FontAttributes="Bold"
                               FontSize="15"
                               VerticalTextAlignment="Center"
                               TextColor="{StaticResource Gray500}"/>

                        <Border Grid.Column="2"
                                Style="{StaticResource WaCompactInputBorderStyle}"
                                WidthRequest="92">
                            <Entry
                                Style="{StaticResource WaCompactNumericEntryStyle}"
                                Text="{Binding SelectedMinutes, Mode=TwoWay}"
                                FontAttributes="Bold"
                                MaxLength="2"/>
                        </Border>
                        <Label Grid.Column="3"
                               Text="{x:Static AppResources.unit_min}"
                               FontAttributes="Bold"
                               FontSize="15"
                               VerticalTextAlignment="Center"
                               TextColor="{StaticResource Gray500}"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Distance & Altitude -->
            <Border Padding="16" IsVisible="{Binding DistanceEnabled}">
                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="16" HorizontalOptions="Start">

                    <VerticalStackLayout Grid.Column="0" Spacing="6">
                        <Label Text="{x:Static AppResources.distance}" Style="{StaticResource WaSectionLabelStyle}"/>
                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6" HorizontalOptions="Start">
                            <Border Grid.Column="0"
                                    Style="{StaticResource WaCompactInputBorderStyle}"
                                    WidthRequest="110">
                                <Entry
                                    Style="{StaticResource WaCompactNumericEntryStyle}"
                                    Text="{Binding Distance, Mode=TwoWay}"
                                    HorizontalTextAlignment="End"
                                    Margin="0,0,10,0"
                                    MaxLength="6"/>
                            </Border>
                            <Label Grid.Column="1"
                                   Text="{x:Static AppResources.unit_km}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray500}"
                                   VerticalTextAlignment="Center"/>
                        </Grid>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                        <Label Text="{x:Static AppResources.altitude}" Style="{StaticResource WaSectionLabelStyle}"/>
                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6" HorizontalOptions="Start">
                            <Border Grid.Column="0"
                                    Style="{StaticResource WaCompactInputBorderStyle}"
                                    WidthRequest="110">
                                <Entry
                                    Style="{StaticResource WaCompactNumericEntryStyle}"
                                    Text="{Binding Altitude, Mode=TwoWay}"
                                    HorizontalTextAlignment="End"
                                    Margin="0,0,10,0"
                                    MaxLength="5"/>
                            </Border>
                            <Label Grid.Column="1"
                                   Text="{x:Static AppResources.unit_hm}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray500}"
                                   VerticalTextAlignment="Center"/>
                        </Grid>
                    </VerticalStackLayout>

                </Grid>
            </Border>

            <!-- Save Button -->
            <BasicButton
                Text="{x:Static AppResources.button_save}"
                Margin="10,8,10,0"
                Command="{Binding SaveActivityCommand}"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
