<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/maui/global"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="workout_app.Pages.ActivityInsertPage"
             x:DataType="ActivityInsertPageModel"
             Title="Aktivität eintragen">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20">

            <!-- DateTime Picker Control -->
            <DateTimePicker
                SelectedDate="{Binding DateTimePicker.SelectedDate}"
                SelectedTime="{Binding DateTimePicker.SelectedTime}"
                SelectedDateDisplay="{Binding DateTimePicker.SelectedDateDisplay}"
                SelectedTimeDisplay="{Binding DateTimePicker.SelectedTimeDisplay}"/>

            <!-- Activity Type -->
            <Border Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Aktivität" FontSize="13" TextColor="{StaticResource Gray500}"/>
                    <Border BackgroundColor="{StaticResource wa-color-input}"
                            HeightRequest="46"
                            Shadow="{x:Null}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Picker
                            Title="Aktivität wählen..."
                            TitleColor="LightGray"
                            ItemsSource="{Binding AvailableActivities}"
                            SelectedItem="{Binding SelectedActivityType}"
                            FontSize="16"
                            TextColor="Black"
                            BackgroundColor="Transparent"
                            HorizontalTextAlignment="Center"/>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Duration -->
            <Border Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Dauer" FontSize="13" TextColor="{StaticResource Gray500}"/>
                    
                    <Grid ColumnDefinitions="*,*,*,*"
                          ColumnSpacing="12"
                          HorizontalOptions="Center">
                        
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource wa-color-input}"
                                Stroke="{StaticResource wa-color-input}"
                                Shadow="{x:Null}"
                                WidthRequest="80"
                                HeightRequest="46">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Picker
                                ItemsSource="{Binding HourOptions}"
                                SelectedItem="{Binding SelectedHours}"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="Black"
                                HorizontalTextAlignment="Center"
                                VerticalOptions="Center"/>
                        </Border>
                        <Label Grid.Column="1"
                               Text="h"
                               FontAttributes="Bold"
                               FontSize="16"
                               VerticalTextAlignment="Center"/>
                        
                        <Border Grid.Column="2"
                                BackgroundColor="{StaticResource wa-color-input}"
                                Stroke="{StaticResource wa-color-input}"
                                Shadow="{x:Null}"
                                WidthRequest="80"
                                HeightRequest="46">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Picker
                                ItemsSource="{Binding MinuteOptions}"
                                SelectedItem="{Binding SelectedMinutes}"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="Black"
                                HorizontalTextAlignment="Center"
                                VerticalOptions="Center"/>
                        </Border>
                        <Label Grid.Column="3"
                               Text="min"
                               FontAttributes="Bold"
                               FontSize="16"
                               VerticalTextAlignment="Center"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Distance & Altitude -->
            <Border Padding="16" IsVisible="{Binding DistanceEnabled}">
                <VerticalStackLayout Spacing="8">

                    <!-- Distance -->
                    <Label Text="Distanz und Höhenmeter" FontSize="13" TextColor="{StaticResource Gray500}"/>
                    
                    

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Border BackgroundColor="{StaticResource wa-color-input}"
                                HeightRequest="46"
                                Shadow="{x:Null}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Entry
                                Text="{Binding Distance, Mode=TwoWay}"
                                Placeholder="0"
                                Keyboard="Numeric"
                                FontSize="16"
                                TextColor="Black"
                                BackgroundColor="Transparent"
                                HorizontalTextAlignment="Center"/>
                        </Border>
                        <Label Grid.Column="1"
                               Text="km"
                               FontSize="16"
                               FontAttributes="Bold"
                               VerticalTextAlignment="Center"
                               WidthRequest="36"/>
                    </Grid>

                    <!-- Altitude -->
                    <Label Text="Höhenmeter" FontSize="13" TextColor="{StaticResource Gray500}"/>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Border BackgroundColor="{StaticResource wa-color-input}"
                                HeightRequest="46"
                                Shadow="{x:Null}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Entry
                                Text="{Binding Altitude, Mode=TwoWay}"
                                Placeholder="0"
                                Keyboard="Numeric"
                                FontSize="16"
                                TextColor="Black"
                                BackgroundColor="Transparent"
                                HorizontalTextAlignment="Center"/>
                        </Border>
                        <Label Grid.Column="1"
                               Text="hm"
                               FontSize="16"
                               FontAttributes="Bold"
                               VerticalTextAlignment="Center"
                               WidthRequest="36"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Save Button -->
            <BasicButton
                Text="Speichern"
                Margin="10,8,10,0"
                Command="{Binding SaveActivityCommand}"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
